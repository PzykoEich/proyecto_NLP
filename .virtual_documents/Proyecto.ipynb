#Load data from kaggle
path = kagglehub.dataset_download("jp797498e/twitter-entity-sentiment-analysis", path='twitter_training.csv')


df = pd.read_csv(path, header=None)
df.columns = ['id','juego','sentimiento','comentario']


df.info()


